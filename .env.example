# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Auth ----
# 32+ chars. openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string

# ---- Database (Postgres) ----
# Use Vercel Postgres / Neon / Supabase. Example:
# postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/arrow_physics

# ---- AI ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Vercel Blob ----
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# ---- Feature flags ----
# Set to "true" to allow demo mode without calling real AI (returns canned arrows)
DEMO_MODE_FALLBACK=true
